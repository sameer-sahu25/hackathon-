# App
APP_ENV=development
APP_NAME=Housing Stability AI
SECRET_KEY=your-super-secret-jwt-key-min-32-chars
DEBUG=True

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb
DATABASE_URL_SYNC=postgresql://user:pass@ep-xxx.neon.tech/neondb

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2000

# Pinecone
PINECONE_API_KEY=xxxxx
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=housing-laws

# OpenAI (embeddings only)
OPENAI_API_KEY=sk-xxxxx

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/v1/sms/webhook

# Google Maps
GOOGLE_MAPS_API_KEY=xxxxx
GOOGLE_MAPS_DAILY_QUOTA=10000

# HUD + 211 APIs
HUD_API_KEY=xxxxx
HUD_API_BASE_URL=https://www.hud.gov
API_211_KEY=xxxxx
API_211_BASE_URL=https://api.211.org

# Data.gov
DATA_GOV_API_KEY=xxxxx
DATA_GOV_API_BASE_URL=https://catalog.data.gov/api/3

# NLIHC
NLIHC_CSV_PATH=/data/nlihc_eviction_laws.csv

# JWT
JWT_SECRET_KEY=xxxxx
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Monitoring
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
POSTHOG_API_KEY=phc_xxxxx
POSTHOG_HOST=https://app.posthog.com
POSTHOG_DEBUG=False
LOG_LEVEL=INFO
LOG_FORMAT=json
APP_VERSION=1.0.0

# CORS
FRONTEND_URL=http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0